#!/usr/bin/env bash
# ==============================================================================
# theme-select - Hugo 主题切换脚本
# ==============================================================================
# 作者:      Hao Feng (F1)
# 版本:      1.0.0
# 创建日期:  2026-05-03
# 许可证:    MIT
#
# 简介:      一键切换 Hugo 静态博客的主题配置，包括 hugo.toml 配置
#             文件和 layouts 布局文件，支持备份恢复机制。
#
# 用法:        ./theme-select <theme-name>
#              ./theme-select                # 显示当前主题和可用主题列表
#              ./theme-select --help         # 显示帮助信息
#              ./theme-select --version      # 显示版本信息
#
# 支持的主题:
#   dark-blue   - 深蓝极简样式
#   study       - 温暖的书房 (Warm Study) 样式
#
# 文件结构:
#   theme-profiles/<theme>/config.toml     # 主题配置文件
#   theme-profiles/<theme>/layouts/        # 主题布局文件
#    .active-theme                         # 当前激活的主题标记
#   hugo.toml.backup                       # 切换前的配置备份
#
# 版本历史:
#   v1.0.0   2026-05-03  Hao Feng (F1)  初始版本
#        - 实现主题切换核心功能
#        - 支持 hugo.toml 配置文件的备份与恢复
#        - 支持 layouts 布局文件的自动复制
#        - 支持 theme-profiles 目录动态发现主题
#        - 添加颜色输出和友好提示信息
#
# ==============================================================================

set -euo pipefail

# ==============================================================================
# 配置与常量
# ==============================================================================

# 项目根目录
PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROFILES_DIR="${PROJECT_ROOT}/theme-profiles"
ACTIVE_FILE="${PROJECT_ROOT}/.active-theme"
CONFIG_FILE="${PROJECT_ROOT}/hugo.toml"
LAYOUTS_DIR="${PROJECT_ROOT}/layouts"

# 版本信息
THEME_SELECT_VERSION="1.0.0"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

# ==============================================================================
# 辅助函数
# ==============================================================================

# 输出信息（绿色）
info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

# 输出错误信息（红色，写入 stderr）
error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

# 输出警告信息（黄色）
warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

# 输出版本信息
show_version() {
    echo "theme-select ${THEME_SELECT_VERSION}"
    echo "作者: Hao Feng (F1)"
    echo "https://github.com/F1/hugo-stack"
}

# 检查主题目录是否存在
# 返回: 0 存在，1 不存在
theme_exists() {
    local theme="$1"
     [[ -d "${PROFILES_DIR}/${theme}" ]]
}

# 获取当前激活的主题名称
# 输出: 主题名，无主题时返回 "none"
get_active_theme() {
    if [[ -f "${ACTIVE_FILE}" ]]; then
        cat "${ACTIVE_FILE}"
    else
        echo "none"
    fi
}

# 写入当前激活的主题到标记文件
# 参数: $1 - 主题名称
set_active_theme() {
    local theme="$1"
    echo "${theme}" > "${ACTIVE_FILE}"
}

# ==============================================================================
# 切换主题
# ==============================================================================

switch_theme() {
    local target_theme="$1"

     # 验证主题是否存在
    if ! theme_exists "${target_theme}"; then
        error "主题 '${target_theme}' 不存在"
        echo ""
        echo "可用的主题:"
        for dir in "${PROFILES_DIR}"/*/; do
            if [[ -d "${dir}" ]]; then
                local name=$(basename "${dir}")
                echo "   - ${name}"
            fi
        done
        exit 1
    fi

    local current_theme=$(get_active_theme)

     # 如果已经是该主题，无需切换
    if [[ "${current_theme}" == "${target_theme}" ]]; then
        info "当前已经是 '${target_theme}' 主题"
        exit 0
    fi

    info "切换主题: ${current_theme} -> ${target_theme}"

     # 检查主题配置文件
    local theme_config="${PROFILES_DIR}/${target_theme}/config.toml"
    if [[ ! -f "${theme_config}" ]]; then
        error "主题配置文件不存在: ${theme_config}"
        exit 1
    fi

     # 检查主题 layouts
    local theme_layouts="${PROFILES_DIR}/${target_theme}/layouts"
    if [[ ! -d "${theme_layouts}" ]]; then
        warn "主题 layouts 目录不存在: ${theme_layouts}"
    fi

     # 备份当前 hugo.toml 配置
    if [[ -f "${CONFIG_FILE}" ]]; then
        cp "${CONFIG_FILE}" "${CONFIG_FILE}.backup"
        info "已备份当前配置到 hugo.toml.backup"
    fi

     # 复制主题配置文件
    cp "${theme_config}" "${CONFIG_FILE}"
    info "已应用主题配置"

     # 清理并复制 layouts
    if [[ -d "${LAYOUTS_DIR}" ]]; then
        rm -rf "${LAYOUTS_DIR}"
        info "已清理旧 layouts"
    fi

    if [[ -d "${theme_layouts}" ]] && [[ -n "$(ls -A ${theme_layouts} 2>/dev/null)" ]]; then
        cp -r "${theme_layouts}" "${LAYOUTS_DIR}"
        info "已应用主题 layouts"
    else
        mkdir -p "${LAYOUTS_DIR}"
        warn "主题无自定义 layouts，已创建空目录"
    fi

     # 更新激活主题标记
    set_active_theme "${target_theme}"

    echo ""
    info "主题切换完成！"
    info "当前主题: ${target_theme}"
    echo ""
    echo "如需预览，运行:"
    echo "  hugo server -D"
}

# ==============================================================================
# 主程序
# ==============================================================================

main() {
     # 无参数时显示当前主题和可用列表
    if [[ $# -eq 0 ]]; then
        echo "用法: $0 <theme-name>"
        echo ""
        echo "当前主题: $(get_active_theme)"
        echo ""
        echo "可用的主题:"
        for dir in "${PROFILES_DIR}"/*/; do
            if [[ -d "${dir}" ]]; then
                local name=$(basename "${dir}")
                local current=""
                if [[ "$(get_active_theme)" == "${name}" ]]; then
                    current=" [当前]"
                fi
                echo "   - ${name}${current}"
            fi
        done
        exit 0
    fi

    local target_theme="$1"

     # 处理帮助命令
    if [[ "${target_theme}" == "-h" ]] || [[ "${target_theme}" == "--help" ]]; then
        show_version
        echo ""
        echo "用法: $0 <theme-name>"
        echo ""
        echo "主题切换脚本 - 在不同的 Hugo 主题配置之间切换"
        echo ""
        echo "命令:"
        echo "   $0              显示当前主题和可用主题列表"
        echo "   $0 <theme>      切换到指定主题"
        echo "   $0 -h, --help   显示此帮助信息"
        echo "   $0 --version    显示版本信息"
        echo ""
        echo "示例:"
        echo "   $0 dark-blue    切换到深蓝极简样式"
        echo "   $0 study        切换到温暖的书房样式"
        exit 0
    fi

     # 处理版本命令
    if [[ "${target_theme}" == "--version" ]]; then
        show_version
        exit 0
    fi

     # 执行主题切换
    switch_theme "${target_theme}"
}

main "$@"
